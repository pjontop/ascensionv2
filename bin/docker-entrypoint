#!/bin/bash -e

# Ensure production can boot before db:prepare by resolving SECRET_KEY_BASE.
# Priority: explicit env var -> production credential -> top-level credential.
if [ "${RAILS_ENV}" = "production" ] && [ -z "${SECRET_KEY_BASE:-}" ]; then
  if [ -n "${RAILS_MASTER_KEY:-}" ]; then
    SECRET_KEY_BASE="$(bin/rails credentials:show 2>/dev/null | ruby -ryaml -e 'd = YAML.safe_load(STDIN.read) || {}; puts d.dig("production", "secret_key_base") || d["secret_key_base"]')"
    export SECRET_KEY_BASE
  fi

  if [ -z "${SECRET_KEY_BASE:-}" ]; then
    echo "ERROR: SECRET_KEY_BASE is missing. Set SECRET_KEY_BASE directly or provide RAILS_MASTER_KEY with secret_key_base in credentials." >&2
    exit 1
  fi
fi

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
