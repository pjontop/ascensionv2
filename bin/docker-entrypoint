#!/bin/bash -e

# Ensure production can boot before db:prepare by resolving SECRET_KEY_BASE.
# Priority: explicit env var -> deterministic derivation from RAILS_MASTER_KEY.
if [ "${RAILS_ENV}" = "production" ] && [ -z "${SECRET_KEY_BASE:-}" ]; then
  if [ -n "${RAILS_MASTER_KEY:-}" ]; then
    SECRET_KEY_BASE="$(ruby -rdigest -e 'print Digest::SHA256.hexdigest(ARGV[0])' "${RAILS_MASTER_KEY}")"
    export SECRET_KEY_BASE
  fi

  if [ -z "${SECRET_KEY_BASE:-}" ]; then
    echo "ERROR: SECRET_KEY_BASE is missing. Set SECRET_KEY_BASE directly or provide RAILS_MASTER_KEY. Note: config/master.key is excluded from Docker build context by .dockerignore." >&2
    exit 1
  fi
fi

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
